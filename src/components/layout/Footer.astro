---
import Container from "../ui/Container.astro";
import { COMPANY } from "../../data/company";
import { FOOTER } from "../../data/footer";
---

<footer class="footer">

    <Container>

        <div class="footer-grid">

            <div>

                <h3 class="footer-logo">

                    {COMPANY.name}

                </h3>

                <p>

                    {FOOTER.description}

                </p>

            </div>

            <div>

                <h4>

                    Navegación

                </h4>

                <ul>

                    {

                        FOOTER.navigation.map((item)=>(

                            <li>

                                <a href={item.href}>

                                    {item.label}

                                </a>

                            </li>

                        ))

                    }

                </ul>

            </div>

            <div>

                <h4>

                    Contacto

                </h4>

                <p>

                    {FOOTER.email}

                </p>

                <p>

                    {FOOTER.location}

                </p>

            </div>

            <div>

                <h4>

                    Síguenos

                </h4>

                <ul>

                    {

                        FOOTER.socials.map((social)=>(

                            <li>

                                <a
                                    href={social.url}
                                    target="_blank"
                                >

                                    {social.name}

                                </a>

                            </li>

                        ))

                    }

                </ul>

            </div>

        </div>

        <div class="footer-bottom">

            <span>

                © {new Date().getFullYear()} {COMPANY.name}

            </span>

            <span>

                Construido con Astro + Tailwind.

            </span>

        </div>

    </Container>

</footer>