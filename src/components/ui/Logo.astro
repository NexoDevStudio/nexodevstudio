---
interface Props {
    variant?: "horizontal" | "icon";
    size?: number;
    showText?: boolean;
}

const { variant = "horizontal", size = 36, showText = true } = Astro.props;

const gradientId = `logo-gradient-${crypto.randomUUID()}`;
---

<div class="logo-wrapper">
    <svg
        width={size}
        height={size}
        viewBox="0 0 64 64"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-label="NexoDevStudio Logo"
    >
        <defs>
            <linearGradient
                id={gradientId}
                x1="32"
                y1="8"
                x2="32"
                y2="56"
                gradientUnits="userSpaceOnUse"
            >
                <stop offset="0%" stop-color="#8B5CF6"></stop>

                <stop offset="100%" stop-color="#06B6D4"></stop>
            </linearGradient>
        </defs>

        <path
            d="M20 44 L20 20 L44 44 L44 20"
            stroke={`url(#${gradientId})`}
            stroke-width="4.8"
            stroke-linecap="round"
            stroke-linejoin="round"></path>

        <circle cx="20" cy="20" r="4" fill={`url(#${gradientId})`}></circle>

        <circle cx="20" cy="44" r="4" fill={`url(#${gradientId})`}></circle>

        <circle cx="44" cy="20" r="4" fill={`url(#${gradientId})`}></circle>

        <circle cx="44" cy="44" r="4" fill={`url(#${gradientId})`}></circle>
    </svg>

    {
        variant === "horizontal" && showText && (
            <span class="logo-text">
                <strong>Nexo </strong> DevStudio
            </span>
        )
    }
</div>
