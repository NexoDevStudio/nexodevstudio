---
interface Props {
  href?: string;
  variant?: "primary" | "secondary";
  target?: string;
}

const {
  href = "#",
  variant = "primary",
  target = "_self"
} = Astro.props;
---

<a
  href={href}
  target={target}
  class:list={[
    "btn",
    variant === "primary" ? "btn-primary" : "btn-secondary"
  ]}
>
  <slot />
</a>