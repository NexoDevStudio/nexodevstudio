---
import Button from "../ui/Button.astro";
import GridBackground from "../ui/GridBackground.astro";
---

<section
    id="hero"
    class="relative flex min-h-screen items-center overflow-hidden pt-32"
>
    <GridBackground />

    <div class="container relative z-10">
        <div
            class="inline-flex items-center gap-2 text-sm font-semibold text-zinc-400 animate-pulse"
        >
            <div class="h-3 w-3 rounded-full bg-purple-500"></div>
            Disponible para nuevos proyectos
        </div>

        <h1
            class="mt-8 max-w-5xl text-6xl font-bold leading-none tracking-tight md:text-8xl"
        >
            Construimos

            <span class="text-violet-400"> productos digitales </span>

            que impulsan negocios.
        </h1>

        <p class="mt-8 max-w-2xl text-xl leading-8 text-zinc-400">
            Creamos landing pages, aplicaciones web, automatizaciones e
            inteligencia artificial con un enfoque en rendimiento, escalabilidad
            y experiencia de usuario.
        </p>

        <div class="mt-12 flex flex-wrap gap-4">
            <Button href="#projects"> Ver proyectos </Button>

            <Button href="#contact" variant="secondary">
                Agendar llamada
            </Button>
        </div>
    </div>
</section>
