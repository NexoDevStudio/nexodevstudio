---
import Container from "../ui/Container.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import { PROCESS } from "../../data/process";
---

<section id="process">
    <Container>
        <SectionHeader
            badge="Proceso"
            title="Una metodología clara para construir mejores productos."
            description="Cada proyecto sigue un proceso definido para asegurar calidad, comunicación y resultados."
        />

        <div class="timeline">
            {
                PROCESS.map((item) => (
                    <article class="timeline-item">
                        <div class="timeline-number">{item.step}</div>

                        <div class="timeline-content">
                            <h3>{item.title}</h3>

                            <p>{item.description}</p>
                        </div>
                    </article>
                ))
            }
        </div>
    </Container>
</section>
