---
import Container from "../ui/Container.astro";
import SectionHeader from "../ui/SectionHeader.astro";

import { Code2, Gauge, Search, Cpu } from "lucide-astro";

export const FEATURES = [
    {
        number: "01",
        icon: Code2,
        title: "Código limpio",
        description:
            "Escribimos software mantenible, escalable y fácil de evolucionar.",
    },
    {
        number: "02",
        icon: Gauge,
        title: "Alto rendimiento",
        description:
            "Nuestros proyectos cargan rápido y están optimizados desde el inicio.",
    },
    {
        number: "03",
        icon: Search,
        title: "SEO desde el primer día",
        description:
            "La estructura está preparada para posicionarse correctamente en Google.",
    },
    {
        number: "04",
        icon: Cpu,
        title: "Tecnologías modernas",
        description:
            "Trabajamos con herramientas actuales para crear productos duraderos.",
    },
];
---

<section id="principles">
    <Container>
        <SectionHeader
            badge="Nuestros principios"
            title="Construimos software con estándares profesionales desde el primer proyecto."
            description="Aplicamos prácticas modernas de desarrollo para crear software rápido, escalable y preparado para crecer junto a tu negocio."
        />

        <div class="trust-grid">
            {
                FEATURES.map((feature) => (
                    <article class="trust-card">
                        <span class="trust-number">
                            {
                                <feature.icon
                                    class="mb-6 "
                                    size={33}
                                    strokeWidth={2}
                                />
                            }
                        </span>

                        <h3 class="trust-title">{feature.title}</h3>

                        <p class="trust-description">{feature.description}</p>
                    </article>
                ))
            }
        </div>
    </Container>
</section>
