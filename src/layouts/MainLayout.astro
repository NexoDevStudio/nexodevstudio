---
import "../styles/global.css";
import { SEO } from "../data/seo";

interface Props {
    title?: string;
    description?: string;
    image?: string;
}

const {
    title = SEO.title,
    description = SEO.description,
    image = SEO.image,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SEO.url).toString();
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />

        <meta name="viewport" content="width=device-width, initial-scale=1" />

        <title>{title}</title>

        <meta name="description" content={description} />

        <meta name="author" content={SEO.author} />

        <meta name="keywords" content={SEO.keywords.join(", ")} />

        <meta name="theme-color" content="#09090b" />
        <meta property="og:locale" content="es_CO" />
        <meta name="robots" content="index,follow" />
        <meta property="og:site_name" content="NexoDevStudio" />
        <link rel="apple-touch-icon" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <!-- <meta name="twitter:site" content="@NexoDevStudio" /> -->

        <link rel="canonical" href={canonical} />

        <!-- Open Graph -->

        <meta property="og:type" content="website" />

        <meta property="og:title" content={title} />

        <meta property="og:description" content={description} />

        <meta property="og:image" content={`${SEO.url}${image}`} />

        <meta property="og:url" content={canonical} />

        <!-- Twitter -->

        <meta name="twitter:card" content="summary_large_image" />

        <meta name="twitter:title" content={title} />

        <meta name="twitter:description" content={description} />

        <meta name="twitter:image" content={`${SEO.url}${image}`} />

        <link rel="icon" href="/favicon.svg" />

        <link rel="manifest" href="/site.webmanifest" />
        <script
            type="application/ld+json"
            set:html={JSON.stringify({
                "@context": "https://schema.org",
                "@graph": [
                    {
                        "@type": "Organization",
                        "@id": `${SEO.url}/#organization`,
                        name: "NexoDevStudio",
                        url: SEO.url,
                        logo: `${SEO.url}/favicon.svg`,
                        description: SEO.description,
                    },
                    {
                        "@type": "WebSite",
                        "@id": `${SEO.url}/#website`,
                        url: SEO.url,
                        name: "NexoDevStudio",
                        description: SEO.description,
                        inLanguage: "es-CO",
                        publisher: {
                            "@id": `${SEO.url}/#organization`,
                        },
                    },
                ],
            })}
        />
    </head>

    <body>
        <slot />
    </body>
</html>
